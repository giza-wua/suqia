rules_version = '2';

// ══════════════════════════════════════════════════════════
//  سُقيا — قواعد أمان Firestore
//  تعتمد على خدمة Firebase Authentication الفعلية (request.auth)
//  بدلاً من التحقق الشكلي على مستوى الواجهة فقط.
//
//  يسجّل كل مستخدم دخوله باسم مستخدم وكلمة مرور عاديين،
//  ويحوّلهما التطبيق إلى بريد إلكتروني صوري (username@suqia.local)
//  لاستخدام خدمة Firebase Auth الرسمية من الخلف، دون أن يشعر
//  المستخدم بأي فرق في تجربة الاستخدام.
//
//  طريقة النشر: من لوحة تحكم Firebase ← قاعدة بيانات Firestore ← القواعد
//  يُلصَق محتوى هذا الملف بالكامل، ثم يُضغط زر النشر (Publish).
// ══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── دوال مساعدة ──
    function isSignedIn() {
      return request.auth != null;
    }
    // يُستخرج اسم المستخدم من البريد الإلكتروني الصوري: "maged@suqia.local" ← "maged"
    function username() {
      return request.auth.token.email.split('@')[0];
    }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(username())).data;
    }
    function myRole() {
      return isSignedIn() ? myProfile().role : null;
    }
    function isAdmin() {
      return isSignedIn() && myRole() == 'admin';
    }
    // محرر أو مسؤول: يملك صلاحية إضافة بيانات الأصول (الترع والكباري والآبار) أو تعديلها أو حذفها
    function isEditorOrAdmin() {
      return isSignedIn() && myRole() in ['admin', 'editor'];
    }

    // ── users: الملفات الشخصية (الاسم والصلاحية) ──
    // ⚠️ شُدِّدت صلاحية القراءة لتتطلب تسجيل الدخول إلزامياً — فقد كانت القراءة
    // المفتوحة للجميع (allow read: if true) تُعرِّض حقل passwordHash القديم
    // (SHA-256 مع قيمة تمليح ثابتة) لأي شخص على الإنترنت، وهو ما كان يتيح هجوم
    // القوة الغاشمة (Brute-force) دون اتصال على الحسابات التي لم تُرحَّل بعد إلى
    // Firebase Auth الفعلي. يجب ترحيل أي حساب قديم فوراً (يُرحَّل تلقائياً بمجرد
    // أول تسجيل دخول ناجح — يُراجَع في ذلك الدالة loginUser في firebase-config.js)،
    // وبعد التأكد من ترحيل جميع المستخدمين، يُحذف حقل passwordHash نهائياً من
    // جميع المستندات. تبقى صلاحية الكتابة (تعديل المستخدمين أو حذفهم) مقتصرة
    // على المسؤول دوماً، دون أي استثناء.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── activityLog: يستطيع أي مستخدم مسجَّل الدخول تسجيل حدث (دخول أو خروج)،
    //    لكن تقتصر صلاحية القراءة والتعديل والحذف على المسؤولين ──
    match /activityLog/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ── specs / linedCanals / bridges / wells وأي مجموعة بيانات أخرى:
    //    صلاحية القراءة لأي مستخدم مسجَّل الدخول، وصلاحية التعديل مقتصرة على المحرر أو المسؤول ──
    match /{collection}/{doc} {
      allow read: if isSignedIn();
      allow write: if isEditorOrAdmin();
    }
  }
}
